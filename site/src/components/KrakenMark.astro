---
// The Kraken brand mark: a white pixel kraken on a sea-ink rounded tile.
// The grid is the canonical one from packages/bridge/src/components.tsx.
interface Props {
  size?: number;
}
const { size = 96 } = Astro.props;

const GRID = [
  '...#####...',
  '..#######..',
  '.#########.',
  '.##.###.##.',
  '.#########.',
  '.#########.',
  '..#.#.#.#..',
  '..#.#.#.#..',
  '.#..#.#..#.',
];
const pixels: { x: number; y: number }[] = [];
GRID.forEach((row, y) => {
  [...row].forEach((ch, x) => {
    if (ch === '#') pixels.push({ x: x + 2, y: y + 3 });
  });
});
---

<svg
  width={size}
  height={size}
  viewBox="0 0 15 15"
  shape-rendering="crispEdges"
  aria-label="Kraken"
  class="kraken-mark"
>
  <rect x="0" y="0" width="15" height="15" rx="3.4" fill="#1E293B"></rect>
  <g fill="rgba(255,255,255,0.94)">
    {pixels.map((p) => <rect x={p.x} y={p.y} width="1.02" height="1.02" />)}
  </g>
</svg>
